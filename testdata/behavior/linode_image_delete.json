{
  "tool": "linode_image_delete",
  "description": "Destroy tool. Pins the private-image-id rejection, the confirm-alone destroy gate, and the bypassed DELETE.",
  "cases": [
    {
      "name": "rejects missing image_id",
      "args": {},
      "expect_error": "image_id must be a non-empty string"
    },
    {
      "name": "confirm alone hits the destroy gate",
      "args": { "image_id": "private/123", "confirm": true },
      "expect_error": "linode_image_delete is destructive. Either:\n  1. Call with dry_run: true first to preview, then call again with\n     confirm: true, confirmed_dry_run: true\n  2. Call with confirm: true, confirm_bypass_dry_run: true to skip preview\n  3. Use yolo: true (only if profile allows)"
    },
    {
      "name": "deletes the image",
      "args": { "image_id": "private/123", "confirm": true, "confirm_bypass_dry_run": true },
      "api_response": {},
      "expect_request": { "method": "DELETE", "path": "/images/private%2F123" }
    },
    {
      "name": "dry_run_preview",
      "args": {
        "image_id": "private/123",
        "dry_run": true
      },
