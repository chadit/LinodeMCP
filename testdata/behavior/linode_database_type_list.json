{
  "tool": "linode_database_type_list",
  "description": "Shared non-integer pagination rejections and the bare list GET the handler issues.",
  "cases": [
    {
      "name": "rejects non-integer page",
      "args": { "page": "x" },
      "expect_error": "page must be an integer"
    },
    {
      "name": "rejects non-integer page_size",
      "args": { "page_size": "x" },
      "expect_error": "page_size must be an integer"
    },
    {
      "name": "lists database types",
      "args": {},
      "api_response": { "data": [], "page": 1, "pages": 1, "results": 0 },
      "expect_request": { "method": "GET", "path": "/databases/types" }
    }
  ]
}
