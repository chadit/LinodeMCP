{
  "tool": "linode_lke_node_recycle",
  "description": "Destroy-capability but Go uses a plain confirm gate (no bypass gate); Python enforces the dispatch bypass gate. Only the agreed cases are pinned: cluster_id/node_id-required and the confirmed+bypassed POST. The confirm-alone gate diverges (see report).",
  "cases": [
    {
      "name": "confirm alone is blocked by the destroy gate",
      "args": {
        "cluster_id": 123,
        "node_id": "12345-abc",
        "confirm": true
      },
      "expect_error": "linode_lke_node_recycle is destructive. Either:\n  1. Call with dry_run: true first to preview, then call again with\n     confirm: true, confirmed_dry_run: true\n  2. Call with confirm: true, confirm_bypass_dry_run: true to skip preview\n  3. Use yolo: true (only if profile allows)"
    },
    {
      "name": "requires cluster_id",
      "args": {
        "confirm": true,
        "confirm_bypass_dry_run": true
      },
      "expect_error": "cluster_id is required"
    },
    {
      "name": "requires node_id",
      "args": {
        "cluster_id": 12345,
        "confirm": true,
        "confirm_bypass_dry_run": true
      },
      "expect_error": "node_id is required"
    },
    {
      "name": "recycles the node",
      "args": {
        "cluster_id": 12345,
        "node_id": "node-1",
        "confirm": true,
        "confirm_bypass_dry_run": true
      },
      "api_response": {},
      "expect_request": {
        "method": "POST",
        "path": "/lke/clusters/12345/nodes/node-1/recycle"
      }
    },
    {
      "name": "dry_run_preview",
      "args": {
        "cluster_id": 12345,
        "node_id": "node-1",
        "dry_run": true
      },
      "api_responses": {
        "GET /lke/clusters/12345/nodes/node-1": {
          "id": "",
          "instance_id": 0,
          "status": ""
        }
      },
      "expect_result": {
        "dry_run": true,
        "tool": "linode_lke_node_recycle",
        "would_execute": {
          "method": "POST",
          "path": "/lke/clusters/12345/nodes/node-1/recycle"
        },
        "current_state": {
          "id": "",
          "instance_id": 0,
          "status": ""
        },
        "dependencies": [],
        "side_effects": [],
        "warnings": []
      }
    }
  ]
}
