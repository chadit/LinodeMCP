{
  "tool": "linode_domain_delete",
  "description": "Domain delete is Destroy: confirm alone is blocked by the bypass gate, and a bypass DELETEs the domain. Missing-id rejection diverges (Go checks id before the gate, Python checks confirm before id) so it is left out; see report.",
  "cases": [
    {
      "name": "confirm alone is blocked by the destroy gate",
      "args": { "domain_id": 5, "confirm": true },
      "expect_error": "linode_domain_delete is destructive. Either:\n  1. Call with dry_run: true first to preview, then call again with\n     confirm: true, confirmed_dry_run: true\n  2. Call with confirm: true, confirm_bypass_dry_run: true to skip preview\n  3. Use yolo: true (only if profile allows)"
    },
    {
      "name": "deletes the domain when authorized",
      "args": { "domain_id": 5, "confirm": true, "confirm_bypass_dry_run": true },
      "api_response": {},
      "expect_request": { "method": "DELETE", "path": "/domains/5" }
    },
    {
      "name": "dry_run_preview",
      "args": {
        "domain_id": 5,
        "dry_run": true
      },
      "api_responses": {
        "GET /domains/5": {
          "axfr_ips": [],
          "created": "",
          "description": "",
          "domain": "example.com",
          "expire_sec": 0,
          "group": "",
          "id": 5,
          "master_ips": [],
          "refresh_sec": 0,
          "retry_sec": 0,
          "soa_email": "",
          "status": "active",
          "tags": [],
          "ttl_sec": 0,
          "type": "master",
          "updated": ""
        },
        "GET /domains/5/records": {
          "data": [
            {
              "id": 41,
              "type": "NS",
              "name": "example.com",
              "target": "ns1.linode.com"
            },
            {
              "id": 42,
              "type": "A",
              "name": "www",
              "target": "203.0.113.10"
            }
          ],
          "page": 1,
          "pages": 1,
          "results": 2
        }
      },
      "expect_result": {
        "dry_run": true,
        "tool": "linode_domain_delete",
        "would_execute": {
          "method": "DELETE",
          "path": "/domains/5"
        },
        "current_state": {
          "axfr_ips": [],
          "created": "",
          "description": "",
          "domain": "example.com",
          "expire_sec": 0,
          "group": "",
          "id": 5,
          "master_ips": [],
          "refresh_sec": 0,
          "retry_sec": 0,
          "soa_email": "",
          "status": "active",
          "tags": [],
          "ttl_sec": 0,
          "type": "master",
          "updated": ""
        },
        "dependencies": [
          {
            "kind": "ns_record",
            "label": "ns1.linode.com",
            "action": "cascade_deleted",
            "note": "NS record for example.com"
          }
        ],
        "side_effects": [],
        "warnings": [
          "Deleting this domain destroys 2 DNS record(s), including 1 NS record(s)."
        ]
      }
    }
  ]
}
