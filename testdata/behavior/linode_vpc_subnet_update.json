{
  "tool": "linode_vpc_subnet_update",
  "description": "VPC subnet update requires vpc_id, subnet_id (integers), and label (with confirm), then PUTs the new label.",
  "cases": [
    {
      "name": "requires vpc_id",
      "args": { "confirm": true },
      "expect_error": "vpc_id is required"
    },
    {
      "name": "requires subnet_id",
      "args": { "confirm": true, "vpc_id": 5 },
      "expect_error": "subnet_id is required"
    },
    {
      "name": "requires label",
      "args": { "confirm": true, "vpc_id": 5, "subnet_id": 7 },
      "expect_error": "label is required"
    },
    {
      "name": "updates the subnet label",
      "args": { "confirm": true, "vpc_id": 5, "subnet_id": 7, "label": "new-label" },
      "api_response": {},
      "expect_request": {
        "method": "PUT",
        "path": "/vpcs/5/subnets/7",
        "body": { "label": "new-label" }
      }
    },
    {
      "name": "requires confirm",
      "args": {"vpc_id": 5, "subnet_id": 7, "label": "new-label"},
      "expect_error": "This modifies the subnet configuration. Set confirm=true to proceed."
    }
  ]
}
