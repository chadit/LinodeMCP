{
  "tool": "linode_instance_disk_update",
  "description": "Pins the shared missing-linode_id and missing-disk_id rejections and the disk-update PUT body.",
  "cases": [
    {
      "name": "rejects missing linode_id",
      "args": { "disk_id": 5, "confirm": true },
      "expect_error": "linode_id is required"
    },
    {
      "name": "rejects missing disk_id",
      "args": { "linode_id": 123, "confirm": true },
      "expect_error": "disk_id is required"
    },
    {
      "name": "updates a disk label",
      "args": { "linode_id": 123, "disk_id": 5, "confirm": true, "label": "newlabel" },
      "api_response": {},
      "expect_request": {
        "method": "PUT",
        "path": "/linode/instances/123/disks/5",
        "body": { "label": "newlabel" }
      }
    },
    {
      "name": "requires confirm",
      "args": {"linode_id": 123, "disk_id": 5, "label": "newlabel"},
      "expect_error": "This modifies the disk configuration. Set confirm=true to proceed."
    }
  ]
}
