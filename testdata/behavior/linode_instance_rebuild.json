          "updated": "",
          "watchdog_enabled": false
        },
        "GET /linode/instances/0/disks": {},
        "GET /linode/instances/5/disks": {
          "data": [
            {
              "id": 7,
              "label": "boot",
              "size": 25600,
              "filesystem": "ext4"
            }
          ],
          "page": 1,
          "pages": 1,
          "results": 1
        }
      },
      "expect_result": {
        "dry_run": true,
        "tool": "linode_instance_rebuild",
        "would_execute": {
          "method": "POST",
          "path": "/linode/instances/5/rebuild"
        },
        "current_state": {
          "alerts": {
            "cpu": 0,
            "io": 0,
            "network_in": 0,
            "network_out": 0,
            "transfer_quota": 0
          },
          "backups": {
            "available": false,
            "enabled": false,
            "last_successful": null,
            "schedule": {
              "day": "",
              "window": ""
            }
          },
          "created": "",
