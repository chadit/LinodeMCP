{
  "tool": "linode_database_postgresql_instance_create",
  "description": "Confirm-gated create POST body. Create-arg validation messages diverge between languages (see report).",
  "cases": [
    {
      "name": "creates a postgresql instance",
      "args": {
        "label": "prod-pg",
