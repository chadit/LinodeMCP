        "body": {
          "label": "prod-pg",
          "type": "g6-nanode-1",
          "engine": "postgresql/16",
          "region": "us-east"
        }
      }
    },
    {
      "name": "requires confirm",
      "args": { "label": "prod-pg", "type": "g6-nanode-1", "engine": "postgresql/16", "region": "us-east" },
      "expect_error": "This creates a billable PostgreSQL Managed Database instance. Set confirm=true to proceed."
    }
  ]
