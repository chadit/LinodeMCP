{
  "tool": "linode_kernel_list",
  "description": "Kernel list shares the page/page_size integer rejections and the bare GET /linode/kernels.",
  "cases": [
    {
      "name": "rejects non-integer page",
      "args": { "page": "x" },
      "expect_error": "page must be an integer"
    },
    {
      "name": "rejects non-integer page_size",
      "args": { "page_size": "x" },
      "expect_error": "page_size must be an integer"
    },
    {
      "name": "lists available kernels",
      "args": {},
      "api_response": { "data": [], "page": 1, "pages": 1, "results": 0 },
      "expect_request": { "method": "GET", "path": "/linode/kernels" }
    }
  ]
}
