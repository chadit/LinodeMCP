{
  "tool": "linode_instance_password_reset",
  "description": "Destroy tool. Pins linode_id-required, root_pass-required, the confirm-alone destroy gate, and the bypassed password POST body.",
  "cases": [
    {
      "name": "requires linode_id",
      "args": {},
      "expect_error": "linode_id is required"
    },
    {
      "name": "requires root_pass",
      "args": { "linode_id": 5 },
      "expect_error": "root_pass is required"
    },
    {
      "name": "confirm alone hits the destroy gate",
      "args": { "linode_id": 5, "root_pass": "SecurePass123", "confirm": true },
      "expect_error": "linode_instance_password_reset is destructive. Either:\n  1. Call with dry_run: true first to preview, then call again with\n     confirm: true, confirmed_dry_run: true\n  2. Call with confirm: true, confirm_bypass_dry_run: true to skip preview\n  3. Use yolo: true (only if profile allows)"
    },
    {
      "name": "resets the root password",
      "args": {
        "linode_id": 5,
        "root_pass": "SecurePass123",
        "confirm": true,
        "confirm_bypass_dry_run": true
      },
      "api_response": {},
      "expect_request": {
        "method": "POST",
        "path": "/linode/instances/5/password",
        "body": { "root_pass": "SecurePass123" }
      }
    },
    {
      "name": "dry_run_preview",
      "args": {
        "linode_id": 5,
        "root_pass": "SecurePass123",
        "dry_run": true
