{
  "tool": "linode_image_sharegroup_image_delete",
  "description": "Destroy tool. The shared-image route uses a numeric image_id. Pins the sharegroup_id rejection, the confirm-alone destroy gate, and the bypassed DELETE.",
  "cases": [
    {
      "name": "rejects missing sharegroup_id",
      "args": {},
      "expect_error": "sharegroup_id is required"
    },
    {
      "name": "confirm alone hits the destroy gate",
      "args": {
        "sharegroup_id": 5,
        "image_id": 7,
        "confirm": true
      },
      "expect_error": "linode_image_sharegroup_image_delete is destructive. Either:\n  1. Call with dry_run: true first to preview, then call again with\n     confirm: true, confirmed_dry_run: true\n  2. Call with confirm: true, confirm_bypass_dry_run: true to skip preview\n  3. Use yolo: true (only if profile allows)"
    },
    {
      "name": "removes the shared image",
      "args": {
        "sharegroup_id": 5,
        "image_id": 7,
        "confirm": true,
        "confirm_bypass_dry_run": true
      },
      "api_response": {},
      "expect_request": {
        "method": "DELETE",
        "path": "/images/sharegroups/5/images/7"
      }
    },
    {
      "name": "dry_run_preview",
      "args": {
        "sharegroup_id": 5,
        "image_id": 7,
        "dry_run": true
      },
      "api_responses": {
        "GET /images/sharegroups/5": {
          "created": "",
          "description": null,
          "expiry": null,
          "id": 0,
          "images_count": 0,
          "is_suspended": false,
          "label": "",
          "members_count": 0,
          "updated": null,
          "uuid": ""
        }
      },
      "expect_result": {
        "dry_run": true,
        "tool": "linode_image_sharegroup_image_delete",
        "would_execute": {
          "method": "DELETE",
          "path": "/images/sharegroups/5/images/7"
        },
        "current_state": {
          "created": "",
          "description": null,
          "expiry": null,
          "id": 0,
          "images_count": 0,
          "is_suspended": false,
          "label": "",
          "members_count": 0,
          "updated": null,
          "uuid": ""
        },
        "dependencies": [],
        "side_effects": [],
        "warnings": []
      }
    }
  ]
}
