{
  "tool": "linode_lke_kubeconfig_get",
  "description": "Returns a kubeconfig secret by design; only the request/validation is compared. Pins cluster_id-required and the single GET.",
  "cases": [
    {
      "name": "rejects missing cluster_id",
      "args": {},
      "expect_error": "cluster_id is required"
    },
    {
      "name": "gets the kubeconfig",
      "args": { "cluster_id": "12345" },
      "api_response": {},
      "expect_request": { "method": "GET", "path": "/lke/clusters/12345/kubeconfig" }
    }
  ]
}
