{
  "tool": "linode_instance_delete",
  "description": "Two-stage destroy flagship. Pins the instance_id-required rejection (through the bypass so both reach it), the confirm-alone destroy gate, and the bypassed delete DELETE.",
  "cases": [
    {
      "name": "requires instance_id",
      "args": { "confirm": true, "confirm_bypass_dry_run": true },
      "expect_error": "instance_id is required"
    },
    {
      "name": "confirm alone hits the destroy gate",
      "args": { "instance_id": 5, "confirm": true },
      "expect_error": "linode_instance_delete is destructive. Either:\n  1. Call with dry_run: true first to preview, then call again with\n     confirm: true, confirmed_dry_run: true\n  2. Call with confirm: true, confirm_bypass_dry_run: true to skip preview\n  3. Use yolo: true (only if profile allows)"
    },
    {
      "name": "deletes the instance",
      "args": { "instance_id": 5, "confirm": true, "confirm_bypass_dry_run": true },
      "api_response": {},
      "expect_request": { "method": "DELETE", "path": "/linode/instances/5" }
    },
