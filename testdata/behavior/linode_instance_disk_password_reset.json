{
  "tool": "linode_instance_disk_password_reset",
  "description": "Pins the shared missing-linode_id, missing-disk_id, and missing-password rejections and the password-reset POST body.",
  "cases": [
    {
      "name": "rejects missing linode_id",
      "args": {},
      "expect_error": "linode_id is required"
    },
    {
      "name": "rejects missing disk_id",
      "args": { "linode_id": 123 },
      "expect_error": "disk_id is required"
    },
    {
      "name": "rejects missing password",
      "args": { "linode_id": 123, "disk_id": 5, "confirm": true },
      "expect_error": "password is required"
    },
    {
      "name": "resets a disk root password",
      "args": { "linode_id": 123, "disk_id": 5, "confirm": true, "password": "S3curePass123" },
      "api_response": {},
      "expect_request": {
        "method": "POST",
        "path": "/linode/instances/123/disks/5/password",
        "body": { "password": "S3curePass123" }
      }
    },
    {
      "name": "requires confirm",
      "args": {"linode_id": 123, "disk_id": 5, "password": "S3curePass123"},
      "expect_error": "This resets the root password for a disk. Set confirm=true to proceed."
    }
  ]
}
