{
  "tool": "linode_database_instance_list",
  "description": "Cross-engine instance list: shared pagination rejections and the bare list GET.",
  "cases": [
    {
      "name": "rejects non-integer page",
      "args": { "page": "x" },
      "expect_error": "page must be an integer"
    },
    {
      "name": "rejects non-integer page_size",
      "args": { "page_size": "x" },
      "expect_error": "page_size must be an integer"
    },
    {
      "name": "lists all database instances",
      "args": {},
      "api_response": { "data": [], "page": 1, "pages": 1, "results": 0 },
      "expect_request": { "method": "GET", "path": "/databases/instances" }
    }
  ]
}
