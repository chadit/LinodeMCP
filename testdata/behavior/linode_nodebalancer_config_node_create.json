{
  "tool": "linode_nodebalancer_config_node_create",
  "description": "Pins the node-create POST body and the shared label/address-required, label-length, and weight-max rejections (with confirm set).",
  "cases": [
    {
      "name": "rejects missing address",
      "args": { "nodebalancer_id": 5, "config_id": 7, "label": "web-1", "confirm": true },
      "expect_error": "address is required"
    },
    {
      "name": "rejects a too-short label",
      "args": { "nodebalancer_id": 5, "config_id": 7, "label": "ab", "address": "192.168.1.5:80", "confirm": true },
      "expect_error": "label must be 3 to 32 characters"
    },
    {
      "name": "rejects a weight above 255",
      "args": { "nodebalancer_id": 5, "config_id": 7, "label": "web-1", "address": "192.168.1.5:80", "weight": 256, "confirm": true },
      "expect_error": "weight must be at most 255"
    },
    {
      "name": "rejects missing label",
      "args": { "nodebalancer_id": 5, "config_id": 7, "address": "192.168.1.5:80", "confirm": true },
      "expect_error": "label is required"
    },
    {
      "name": "posts the node create body",
      "args": { "nodebalancer_id": 5, "config_id": 7, "label": "web-1", "address": "192.168.1.5:80", "confirm": true },
      "api_response": { "id": 9, "config_id": 7, "nodebalancer_id": 5, "label": "web-1", "address": "192.168.1.5:80" },
      "expect_request": {
        "method": "POST",
        "path": "/nodebalancers/5/configs/7/nodes",
        "body": { "label": "web-1", "address": "192.168.1.5:80" }
      }
    },
    {
      "name": "requires confirm",
      "args": {"nodebalancer_id": 5, "config_id": 7, "label": "web-1", "address": "192.168.1.5:80"},
      "expect_error": "This creates a NodeBalancer node. Set confirm=true to proceed."
    },
    {
      "name": "accepts mode none (was wrongly rejected before the proto-enum migration)",
      "args": { "nodebalancer_id": 5, "config_id": 7, "label": "web-1", "address": "192.168.1.5:80", "mode": "none", "confirm": true },
      "api_response": { "id": 10, "config_id": 7, "nodebalancer_id": 5, "label": "web-1", "address": "192.168.1.5:80", "mode": "none" },
      "expect_request": {
        "method": "POST",
        "path": "/nodebalancers/5/configs/7/nodes",
        "body": { "label": "web-1", "address": "192.168.1.5:80", "mode": "none" }
      }
    },
    {
      "name": "rejects an invalid mode",
      "args": { "nodebalancer_id": 5, "config_id": 7, "label": "web-1", "address": "192.168.1.5:80", "mode": "bogus", "confirm": true },
      "expect_error": "mode must be one of: accept, backup, drain, none, reject"
    }
  ]
}
