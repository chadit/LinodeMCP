{
  "tool": "linode_lke_acl_get",
  "description": "Pins cluster_id-required and the single GET.",
  "cases": [
    {
      "name": "rejects missing cluster_id",
      "args": {},
      "expect_error": "cluster_id is required"
    },
    {
      "name": "gets the control plane acl",
      "args": { "cluster_id": "12345" },
      "api_response": { "acl": { "enabled": true, "addresses": { "ipv4": [], "ipv6": [] } } },
      "expect_request": { "method": "GET", "path": "/lke/clusters/12345/control_plane_acl" }
    }
  ]
}
