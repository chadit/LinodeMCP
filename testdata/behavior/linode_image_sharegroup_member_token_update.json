{
  "tool": "linode_image_sharegroup_member_token_update",
  "description": "With confirm set both languages reach the sharegroup_id check. Success PUTs the member token label.",
  "cases": [
    {
      "name": "rejects missing sharegroup_id",
      "args": {
        "confirm": true
      },
      "expect_error": "sharegroup_id is required"
    },
    {
      "name": "updates a member token label",
      "args": {
        "sharegroup_id": 5,
        "token_uuid": "123e4567-e89b-12d3-a456-426614174000",
        "label": "new-label",
        "confirm": true
      },
      "api_response": {},
      "expect_request": {
        "method": "PUT",
        "path": "/images/sharegroups/5/members/123e4567-e89b-12d3-a456-426614174000",
        "body": {
          "label": "new-label"
        }
      }
    },
    {
      "name": "requires confirm",
      "args": {
        "sharegroup_id": 5,
        "token_uuid": "123e4567-e89b-12d3-a456-426614174000",
        "label": "new-label"
      },
      "expect_error": "This updates an image share group member token. Set confirm=true to proceed."
    }
  ]
}
