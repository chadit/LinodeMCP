{
  "tool": "linode_instance_interface_history_list",
  "description": "Pins the shared non-integer page rejection and the interface-history list GET. linode_id rejection text diverges (see report).",
  "cases": [
    {
      "name": "rejects non-integer page",
      "args": { "linode_id": 123, "page": "x" },
      "expect_error": "page must be an integer"
    },
    {
      "name": "lists interface history",
      "args": { "linode_id": 123 },
      "api_response": { "data": [], "page": 1, "pages": 1, "results": 0 },
      "expect_request": { "method": "GET", "path": "/linode/instances/123/interfaces/history" }
    }
  ]
}
