{
  "tool": "linode_nodebalancer_update",
  "description": "Pins the update PUT body and the shared nodebalancer_id-required rejection (with confirm set). Go requires confirm; Python does not (see report).",
  "cases": [
    {
      "name": "rejects missing nodebalancer_id",
      "args": { "confirm": true },
      "expect_error": "nodebalancer_id is required"
    },
    {
      "name": "puts the update body",
      "args": { "nodebalancer_id": 789, "label": "newlabel", "confirm": true },
      "api_response": { "id": 789, "label": "newlabel", "region": "us-east" },
      "expect_request": {
        "method": "PUT",
        "path": "/nodebalancers/789",
        "body": { "label": "newlabel" }
      }
    },
    {
      "name": "requires confirm",
      "args": {"nodebalancer_id": 789, "label": "newlabel"},
      "expect_error": "This updates a NodeBalancer. Set confirm=true to proceed."
    }
  ]
}
