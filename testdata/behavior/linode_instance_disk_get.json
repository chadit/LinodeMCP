{
  "tool": "linode_instance_disk_get",
  "description": "Pins the shared missing-linode_id and missing-disk_id rejections and the disk-get GET.",
  "cases": [
    {
      "name": "rejects missing linode_id",
      "args": {},
      "expect_error": "linode_id is required"
    },
    {
      "name": "rejects missing disk_id",
      "args": { "linode_id": 123 },
      "expect_error": "disk_id is required"
    },
    {
      "name": "gets a disk",
      "args": { "linode_id": 123, "disk_id": 5 },
      "api_response": {},
      "expect_request": { "method": "GET", "path": "/linode/instances/123/disks/5" }
    }
  ]
}
