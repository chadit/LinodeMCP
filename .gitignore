# Override: the global ~/.gitignore excludes /.github/ broadly, but this
# repo ships its own CI workflows. Re-include them here.
!/.github/
!/.github/**

# Override: the global ~/.gitignore excludes **/docs/ broadly, but this
# repo ships host integration examples and profile docs under docs/.
# Re-include them here.
!/docs/
!/docs/**
